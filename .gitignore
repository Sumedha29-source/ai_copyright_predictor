# ==============================
# ArtChain — .gitignore
# ==============================


# ==============================
# Environment Variables
# NEVER commit these
# ==============================

.env
.env.local
.env.development
.env.production
.env.test
.env.staging
*.env


# ==============================
# Node Modules
# Reinstall with npm install
# ==============================

node_modules/
**/node_modules/


# ==============================
# Build Output
# ==============================

dist/
build/
out/
.next/
.nuxt/
.output/


# ==============================
# Frontend Vite
# ==============================

frontend/dist/
frontend/.vite/
frontend/coverage/


# ==============================
# Backend
# ==============================

backend/uploads/
backend/dist/
backend/logs/
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ==============================
# Hardhat / Contracts
# ==============================

contracts/artifacts/
contracts/cache/
contracts/coverage/
contracts/coverage.json
contracts/typechain/
contracts/typechain-types/


# ==============================
# SDK
# ==============================

sdk/dist/
sdk/coverage/
sdk/.nyc_output/


# ==============================
# Package Lock Files
# Optional — some teams commit
# package-lock.json
# ==============================

# package-lock.json
# yarn.lock


# ==============================
# OS Files
# ==============================

# Mac
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ==============================
# IDE / Editor Files
# ==============================

# VS Code
.vscode/
*.code-workspace

# IntelliJ / WebStorm
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*.swn

# Emacs
*~
\#*\#


# ==============================
# Testing
# ==============================

coverage/
.nyc_output/
*.lcov
test-results/
junit.xml


# ==============================
# Temporary Files
# ==============================

tmp/
temp/
*.tmp
*.temp
*.cache


# ==============================
# Crypto / Security
# NEVER commit these
# ==============================

*.pem
*.key
*.cert
*.p12
*.pfx
keystore.json
wallet.json
private-key.txt


# ==============================
# TypeScript
# ==============================

*.tsbuildinfo
tsconfig.tsbuildinfo


# ==============================
# Misc
# ==============================

*.gz
*.zip
*.tar
*.rar
.vercel
.netlify
.railway